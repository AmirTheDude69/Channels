{
  "name": "@channels/mac-agent",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "channels-agent": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts run --server-url ws://127.0.0.1:8787/ws/agent",
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@channels/shared": "workspace:*",
    "commander": "^14.0.1",
    "dotenv": "^17.2.2",
    "ws": "^8.18.3",
    "zod": "^4.1.11"
  }
}
