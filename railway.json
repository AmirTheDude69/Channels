{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile=false && pnpm build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @channels/control-plane start",
    "restartPolicyType": "ON_FAILURE"
  }
}
